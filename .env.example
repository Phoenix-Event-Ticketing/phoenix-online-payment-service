PORT=4002
NODE_ENV=development
MONGO_URI=mongodb://localhost:27017/phoenix_payment_service

# JWT secret or public key used to verify tokens from User Service
JWT_SECRET=change_me_in_real_env

# Base URLs for other Phoenix services
BOOKING_SERVICE_BASE_URL=http://localhost:4001
USER_SERVICE_BASE_URL=http://localhost:4000

# Logging (error|warn|info|debug) — logs are JSON lines to stdout/stderr
LOG_LEVEL=info

# CORS: * or comma-separated origins, e.g. https://app.example.com,https://admin.example.com
CORS_ORIGIN=*

# GCP Artifact Registry / deploy (used by CI scripts or local tooling; not read by the Node app unless you wire it)
GCP_PROJECT_ID=phoenix-event-booking
GCP_REGION=asia-south1
GCP_ARTIFACT_REGISTRY=phoenix-images
GCP_IMAGE_NAME=payment-service

# Argo CD (set locally or in your secrets manager; do not commit real passwords)
ARGOCD_PASSWORD=
