{
  "name": "phoenix-payment-service",
  "version": "1.0.0",
  "description": "Payment microservice for the Phoenix Online platform (payments and refunds with MongoDB and JWT auth).",
  "main": "src/server.js",
  "type": "commonjs",
  "scripts": {
    "start": "cross-env NODE_ENV=production node src/server.js",
    "dev": "cross-env NODE_ENV=development nodemon src/server.js",
    "lint": "eslint \"**/*.js\"",
    "format": "prettier --write \"src/**/*.js\"",
    "test": "jest",
    "test:coverage": "jest --coverage --coverageReporters=lcov --coverageDirectory=coverage",
    "test:unit": "jest --runInBand --testPathPattern=unit",
    "test:integration": "jest --runInBand --testPathPattern=integration"
  },
  "keywords": [
    "payments",
    "phoenix",
    "microservice",
    "node",
    "express",
    "mongodb"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.7.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.0",
    "express-rate-limit": "^7.0.0",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.4.0",
    "morgan": "^1.10.0",
    "swagger-ui-express": "^5.0.0",
    "uuid": "^9.0.1",
    "winston": "^3.19.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "cross-env": "^7.0.3",
    "eslint": "^9.0.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.0",
    "prettier": "^3.2.5",
    "supertest": "^6.3.4"
  }
}
