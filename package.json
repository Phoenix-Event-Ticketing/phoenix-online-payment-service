{
  "name": "phoenix-payment-service",
  "version": "1.0.0",
  "description": "Payment microservice for the Phoenix Online platform (payments and refunds with MongoDB and JWT auth).",
  "main": "src/server.mjs",
  "type": "commonjs",
  "scripts": {
    "start": "cross-env NODE_ENV=production node src/server.mjs",
    "dev": "cross-env NODE_ENV=development nodemon src/server.mjs",
    "lint": "eslint \"**/*.{js,mjs}\"",
    "format": "prettier --write \"src/**/*.{js,mjs}\"",
    "test": "jest",
    "test:coverage": "jest --coverage --coverageReporters=lcov --coverageDirectory=coverage",
    "test:unit": "jest --runInBand --testPathPattern=unit",
    "test:integration": "jest --runInBand --testPathPattern=integration",
    "audit": "node scripts/run-npm-cli.js audit",
    "audit:high": "node scripts/run-npm-cli.js audit --audit-level=high",
    "audit:high:npm9": "npx --yes npm@9.9.2 audit --audit-level=high"
  },
  "keywords": [
    "payments",
    "phoenix",
    "microservice",
    "node",
    "express",
    "mongodb"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18.18.0"
  },
  "dependencies": {
    "@opentelemetry/auto-instrumentations-node": "^0.73.0",
    "@opentelemetry/exporter-jaeger": "^2.7.0",
    "@opentelemetry/sdk-node": "^0.215.0",
    "axios": "^1.7.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.0",
    "express-rate-limit": "^7.0.0",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.4.0",
    "morgan": "^1.10.0",
    "prom-client": "^15.1.3",
    "swagger-ui-express": "^5.0.0",
    "uuid": "^9.0.1",
    "winston": "^3.19.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.16.0",
    "cross-env": "^7.0.3",
    "eslint": "^9.16.0",
    "jest": "^30.3.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.2.5",
    "supertest": "^7.2.2"
  },
  "overrides": {
    "flatted": "3.4.2"
  }
}
